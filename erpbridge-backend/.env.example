# ================================
# App
# ================================
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ================================
# Database
# ================================
DB_HOST=your-db-host
DB_PORT=3306
DB_USER=your-db-user
DB_PASSWORD=your-db-password
DB_NAME=your-db-name

# ================================
# Auth / JWT
# ================================
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=1209600
JWT_SECRET=your-jwt-secret-at-least-32-characters-long

# ================================
# Email (Gmail SMTP)
# ================================
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
FRONTEND_URL=http://localhost:5173

# Email that receives order notifications and error alerts
NOTIFICATION_EMAIL=orders@yourcompany.com
ADMIN_ERROR_EMAIL=admin@yourcompany.com

# ================================
# Images
# ================================
IMAGES_BASE_URL=http://localhost:3001/images

# Comma-separated list of directories where product images are stored
IMAGES_PATHS=C:\\path\\to\\images1,C:\\path\\to\\images2

# ================================
# Redis
# ================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
