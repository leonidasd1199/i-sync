# ---------- Build Stage ----------
FROM node:22 AS builder
WORKDIR /node/app/apps/api

COPY package*.json ./
RUN npm ci

COPY tsconfig*.json nest-cli.json ./
COPY migrate-mongo-config.js ./
COPY src ./src

RUN npm run build

# ---------- Runtime (Dev/Watch) ----------
FROM node:22
WORKDIR /node/app/apps/api

ENV NODE_ENV=development
ENV CHOKIDAR_USEPOLLING=1
ENV WATCHPACK_POLLING=true
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# System dependencies needed by Playwright Chromium
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends \
  libnss3 libnspr4 libatk1.0-0 libatk-bridge2.0-0 libcups2 libdrm2 \
  libxkbcommon0 libxcomposite1 libxdamage1 libxfixes3 libxrandr2 \
  libgbm1 libasound2 libpango-1.0-0 libcairo2 libatspi2.0-0 \
  libxshmfence1 \
  && rm -rf /var/lib/apt/lists/*

COPY package*.json ./
COPY --from=builder /node/app/apps/api/node_modules ./node_modules
COPY tsconfig*.json nest-cli.json ./
COPY migrate-mongo-config.js ./
COPY --from=builder /node/app/apps/api/src ./src
COPY --from=builder /node/app/apps/api/dist ./dist

# Pin/install the Chromium browser version that matches the Playwright package
RUN npx playwright install chromium

EXPOSE 3000

CMD ["npm", "run", "start:dev"]
